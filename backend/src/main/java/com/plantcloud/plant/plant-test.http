@baseUrl = http://localhost:8080
@contentType = application/json

### 1. AI生成植物模板参数 - 正常测试
POST {{baseUrl}}/plant-config/ai-generate
Content-Type: {{contentType}}

{
  "plantName": "网纹草"
}

###

### 2. AI生成植物模板参数 - 再测一个品种
POST {{baseUrl}}/plant-config/ai-generate
Content-Type: {{contentType}}

{
  "plantName": "秋海棠"
}

###

### 3. AI生成植物模板参数 - 再测一个品种
POST {{baseUrl}}/plant-config/ai-generate
Content-Type: {{contentType}}

{
  "plantName": "鹿角蕨"
}

###

### 4. AI生成植物模板参数 - 参数校验测试（空名称，预期失败）
POST {{baseUrl}}/plant-config/ai-generate
Content-Type: {{contentType}}

{
  "plantName": ""
}

###

### 5. 新增植物 - 正常测试（使用AI生成好的模板数据）
POST {{baseUrl}}/plants
Content-Type: {{contentType}}

{
  "plantName": "网纹草",
  "templateData": {
    "plantName": "网纹草",
    "species": null,
    "tempMin": 18,
    "tempMax": 26,
    "humidityMin": 65,
    "humidityMax": 85,
    "lightMin": 2000,
    "lightMax": 6000,
    "tempRiseSensitive": 0.7,
    "humidityDropSensitive": 1.0,
    "lightRiseSensitive": 0.6,
    "careLevel": "hard",
    "summary": "网纹草喜欢温暖湿润环境，对空气干燥比较敏感。"
  }
}

###

### 6. 新增植物 - 正常测试（秋海棠）
POST {{baseUrl}}/plants
Content-Type: {{contentType}}

{
  "plantName": "秋海棠",
  "templateData": {
    "plantName": "秋海棠",
    "species": null,
    "tempMin": 16,
    "tempMax": 28,
    "humidityMin": 55,
    "humidityMax": 75,
    "lightMin": 3000,
    "lightMax": 10000,
    "tempRiseSensitive": 0.6,
    "humidityDropSensitive": 0.7,
    "lightRiseSensitive": 0.5,
    "careLevel": "medium",
    "summary": "秋海棠适合温暖湿润和明亮散射光环境，怕积水和暴晒。"
  }
}

###

