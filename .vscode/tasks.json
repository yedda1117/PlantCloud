{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "fronted: dev",
      "type": "npm",
      "script": "dev",
      "path": "fronted",
      "options": {
        "cwd": "${workspaceFolder}/fronted"
      },
      "isBackground": true,
      "problemMatcher": [
        "$tsc-watch"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "fronted: build",
      "type": "npm",
      "script": "build",
      "path": "fronted",
      "options": {
        "cwd": "${workspaceFolder}/fronted"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
